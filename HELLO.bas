10 REM *** STREET PLAYER ***
20 REM APPLESOFT / 80-COL (PR#3)
30 PR# 3 : HOME
40 PRINT "                                 STREET PLAYER"
45 PRINT "--------------------------------------------------------------------------------"
50 PRINT : PRINT "PRESS ANY KEY TO START"
60 RS = RS + 1 : IF PEEK(49152) < 128 THEN GOTO 60
70 POKE 49168, 0
80 RS = RND(-RS)
90 GOSUB 9000 : REM INIT

100 REM ======= MAIN LOOP =======
110 GOSUB 1000 : REM DRAW STATUS
120 GOSUB 2000 : REM MENU + INPUT
130 IF QT = 1 THEN GOTO 500
140 GOSUB 3000 : REM ADVANCE ONE DAY
150 IF GO = 1 THEN GOTO 600
160 GOTO 100

500 IF DE > 0 THEN M$ = "NOBODY RETIRES WHILE THEY STILL OWE." : QT = 0 : GOTO 100
502 IF CP = -1 THEN M$ = "YOU CAN'T LEAVE TOWN WITH THE COPS ON YOU." : QT = 0 : GOTO 100
504 IF HD > 0 THEN M$ = "YOUR GUYS ARE STILL OUT ON A JOB." : QT = 0 : GOTO 100
506 NW = CA
508 FOR J = 1 TO 3
510 SQ = V(J) : IF D(J) < SQ THEN SQ = D(J)
512 NW = NW + SQ * P(J)
514 NEXT J
516 PRINT : PRINT "YOU RETIRE. NET WORTH: $";NW
518 END

600 PRINT : PRINT M$ : PRINT "*** GAME OVER ***"
610 END

1000 REM ======= STATUS DISPLAY =======
1010 HOME
1020 PRINT "                                 STREET PLAYER"
1030 PRINT "--------------------------------------------------------------------------------";
1040 PRINT MID$(DW$, WD * 3 + 1, 3);TAB(10);"CASH: $";CA;TAB(30);"DEBT: $";DE;TAB(52);"SHOPS: ";SH;TAB(66);"MUSCLE: ";MU
1050 PRINT "--------------------------------------------------------------------------------";
1060 PRINT "COMMODITY";TAB(20);"STREET PRICE";TAB(40);"YOU HOLD";TAB(60);"DEMAND"
1070 FOR J = 1 TO 3
1080 PRINT N$(J);TAB(20);"$";P(J);TAB(40);V(J);TAB(60);D(J)
1090 NEXT J
1095 PRINT "--------------------------------------------------------------------------------";

1100 REM -- WEEKLY CASH FLOW --
1110 EF = SH : FM = MU - HG + 1 : IF EF > FM THEN EF = FM
1120 FM = FM - EF : IF FM < 0 THEN FM = 0
1130 CN = NL : IF CN > FM THEN CN = FM
1140 TK = 0 : IF CN < 1 THEN GOTO 1190
1150 FOR I = 1 TO CN
1160 MP = INT(LB(I) * .1) : IF MP < 50 THEN MP = 50
1170 IF MP > LB(I) THEN MP = LB(I)
1180 TK = TK + MP : NEXT I
1190 MP = 0 : IF DE = 0 THEN GOTO 1220
1200 MP = INT(DE * .1) : IF MP < 50 THEN MP = 50
1210 IF MP > DE THEN MP = DE
1220 PRINT "WEEKLY IN:";TAB(20);"PROTECTION $";EF * SR;TAB(60);"LOANS $";TK
1230 PRINT "WEEKLY OUT:";TAB(20);"PAYROLL $";MU * PW;TAB(60);"LOANS $";MP
1240 REM -- END WEEKLY CASH FLOW --

1300 REM -- LOAN BOOK --
1310 IF NL = 0 THEN GOTO 1350
1320 TL = 0
1330 FOR I = 1 TO NL : TL = TL + LB(I) : NEXT I
1340 PRINT TAB(14);"ON THE STREET: $";TL;" ACROSS ";NL;" LOAN(S)"
1350 PRINT "--------------------------------------------------------------------------------"
1360 IF M$ = "" THEN RETURN
1370 IF LEN(M$) <= 80 THEN PRINT M$ : M$ = "" : RETURN
1380 PRINT LEFT$(M$, 80) : PRINT MID$(M$, 81) : M$ = ""
1390 RETURN

2000 REM ======= MENU (ONE ACTION = ONE DAY) =======
2010 AC = 0 : WT = 0
2020 TV = V(1) + V(2) + V(3)
2030 CB = 0
2040 FOR I = 1 TO 3 : IF CA >= P(I) THEN CB = 1
2050 NEXT I
2060 PRINT "";
2070 IF CB = 1 THEN PRINT "(B)UY ";
2080 IF TV > 0 THEN PRINT "(S)ELL ";
2090 PRINT "(L)OAN ";
2100 IF CA >= SL THEN PRINT "(P)ROTECTION ";
2110 IF MU > 0 OR INT(CA / PW) - MU >= 1 THEN PRINT "(M)USCLE ";
2120 PRINT "(W)AIT (R)ETIRE";
2130 GET A$ : PRINT
2140 IF A$ = "B" AND CB = 1 THEN GOSUB 4000
2150 IF A$ = "S" AND TV > 0 THEN GOSUB 4500
2160 IF A$ = "L" THEN GOSUB 5000
2170 IF A$ = "P" AND CA >= SL THEN GOSUB 5500
2180 IF A$ = "M" AND (MU > 0 OR INT(CA / PW) - MU >= 1) THEN GOSUB 5700
2190 IF A$ = "R" THEN QT = 1 : RETURN
2200 IF A$ = "W" THEN AC = 1 : WT = 1
2210 IF AC = 0 THEN GOSUB 1000 : GOTO 2010
2220 RETURN

3000 REM ======= ADVANCE ONE DAY =======
3010 DY = DY + 1 : WD = WD + 1

3020 REM -- RANDOM EVENTS (WAIT DAYS ONLY) --
3030 IF WT = 1 AND CP = -1 AND RND(1) < .04 THEN M$ = "THE COPS RAIDED YOU. BUSTED." : GO = 1 : RETURN
3040 IF WT = 1 AND CP = 0 AND (NT = 1 OR RND(1) < .03) THEN NT = 0 : GOSUB 6000
3050 IF WT = 1 AND RND(1) < .10 / (1 + (MU - HG) * 2) THEN GOSUB 6500
3060 IF WT = 1 AND NL < 8 AND RND(1) < .02 THEN GOSUB 6600
3070 IF WT = 1 AND HD = 0 AND MU >= 3 AND RND(1) < .05 THEN GOSUB 7500
3080 IF HD > 0 THEN HD = HD - 1 : IF HD = 0 THEN GOSUB 7600

3100 REM -- DAILY: LOAN OUT, DEBT ACCRUES --
3110 IF NL > 0 THEN FOR I = 1 TO NL : LB(I) = INT(LB(I) * 1.007 + .5) : NEXT I
3120 IF DE > 0 THEN DE = INT(DE * 1.007 + .5)

3200 REM -- DAILY: DEMAND DRIVES STREET PRICE --
3210 FOR J = 1 TO 3
3220 D(J) = INT(DM(J) * (.5 + RND(1)))
3230 P(J) = INT(B(J) * (D(J) / DM(J)) ^ 1.4 + .5)
3240 IF P(J) < 1 THEN P(J) = 1
3250 NEXT J
3260 IF CP = 1 THEN CC = CC - 1 : IF CC <= 0 THEN CP = 0

3300 REM -- WEEKLY GATE --
3310 IF WD < 7 THEN RETURN

3500 REM ======= WEEKLY: INCOME, PAYROLL, DEBT =======
3510 WD = 0 : FM = MU - HG + 1
3520 EF = SH : IF EF > FM THEN EF = FM
3530 FM = FM - EF : IF FM < 0 THEN FM = 0
3540 CL = NL : IF CL > FM THEN CL = FM
3550 TK = 0 : PD = 0 : CA = CA + EF * SR
3560 IF CL < 1 THEN GOTO 3600
3570 FOR I = 1 TO CL
3580 MP = INT(LB(I) * .1) : IF MP < 50 THEN MP = 50
3585 IF MP >= LB(I) THEN MP = LB(I) : PD = PD + 1
3590 CA = CA + MP : LB(I) = LB(I) - MP : TK = TK + MP
3595 NEXT I

3600 IF EF > 0 THEN E$ = "PROTECTION PAID $" + STR$(EF * SR) + "." : GOSUB 8000
3605 IF TK > 0 THEN E$ = "YOUR GUYS BROUGHT IN $" + STR$(TK) + "." : GOSUB 8000
3610 IF PD > 0 THEN GOSUB 3900
3620 PY = MU * PW
3630 IF PY > CA THEN MU = 0 : HG = 0 : HD = 0 : E$ = "NO PAYROLL. YOUR GUYS WALKED." : GOSUB 8000 : GOTO 3650
3640 CA = CA - PY : IF PY > 0 THEN E$ = "PAYROLL COST YOU $" + STR$(PY) + "." : GOSUB 8000
3650 IF DE = 0 THEN RETURN
3660 MP = INT(DE * .1) : IF MP < 50 THEN MP = 50
3670 IF MP > DE THEN MP = DE
3680 IF MP > CA THEN M$ = "YOU MISSED A LOAN REPAYMENT. YOU SLEEP WITH THE FISHES." : GO = 1 : RETURN
3690 CA = CA - MP : DE = DE - MP
3695 E$ = "YOU REPAID $" + STR$(MP) + " OFF YOUR DEBT." : GOSUB 8000
3699 RETURN

3900 REM ======= REMOVE PAID-OFF LOANS =======
3910 K = 0
3920 FOR I = 1 TO NL
3930 IF LB(I) > 0 THEN K = K + 1 : LB(K) = LB(I)
3940 NEXT I
3950 NL = K
3960 E$ = STR$(PD) + " LOAN(S) PAID OFF IN FULL." : GOSUB 8000
3970 RETURN

4000 REM ======= BUY =======
4010 SM = 0 : GOSUB 7000 : IF J = 0 THEN RETURN
4020 SP = P(J)
4030 MX = INT(CA / SP) : IF MX < 1 THEN M$ = "YOU CAN'T AFFORD ANY " + N$(J) + "." : RETURN
4040 PRINT N$(J);" $";SP;TAB(20);"100+ $";INT(SP * .75);TAB(36);"500+ $";INT(SP * .5);TAB(52);"5000+ $";INT(SP * .25)
4090 PRINT "HOW MANY? (ENTER FOR ";MX;") ";: INPUT A$
4100 Q = MX : IF A$ <> "" THEN Q = VAL(A$)
4105 IF Q < 1 THEN RETURN
4110 UP = SP
4120 IF Q >= 100 THEN UP = INT(SP * .75)
4130 IF Q >= 500 THEN UP = INT(SP * .5)
4140 IF Q >= 5000 THEN UP = INT(SP * .25)
4150 IF UP < 1 THEN UP = 1
4160 PRINT "TOTAL: $";Q * UP;" AT $";UP;"/UNIT. BUY? (Y/N)";
4170 GET A$ : PRINT : IF A$ = "N" THEN RETURN
4180 IF Q * UP > CA THEN M$ = "NOT ENOUGH CASH." : RETURN
4190 CA = CA - Q * UP : V(J) = V(J) + Q : AC = 1
4200 TR = Q * UP : IF CP = 0 AND TR > 3000 AND RND(1) < (TR / 20000) THEN NT = 1
4210 RETURN

4500 REM ======= SELL =======
4510 SM = 1 : GOSUB 7000 : IF J = 0 THEN RETURN
4515 IF D(J) = 0 THEN M$ = "NO BUYERS FOR " + N$(J) + " TODAY." : RETURN
4520 MX = V(J) : IF D(J) < MX THEN MX = D(J)
4530 IF MX < 1 THEN M$ = "YOU HAVE NO " + N$(J) + " TO SELL." : RETURN
4540 PRINT "YOU CAN SELL UP TO ";MX;" AT $";P(J);"/UNIT."
4550 PRINT "HOW MANY? (ENTER FOR ";MX;") ";: INPUT A$
4555 Q = MX : IF A$ <> "" THEN Q = VAL(A$)
4560 IF Q < 1 OR Q > MX THEN M$ = "CAN'T DO THAT." : RETURN
4570 PRINT "TOTAL: $";Q * P(J);". SELL? (Y/N)";
4580 GET A$ : PRINT : IF A$ = "N" THEN RETURN
4590 CA = CA + Q * P(J) : V(J) = V(J) - Q : D(J) = D(J) - Q : AC = 1
4595 RETURN

5000 REM ======= LOANS =======
5010 CL = 5000 - DE : IF CL < 0 THEN CL = 0
5020 PRINT "DEBT: $";DE;"   YOU CAN BORROW $";CL;" MORE."
5030 PRINT "(B)ORROW  (R)EPAY";
5040 GET A$ : PRINT
5050 IF A$ = "B" THEN INPUT "AMOUNT? ";Q : IF Q > 0 AND Q <= CL THEN DE = DE + Q : CA = CA + Q : AC = 1
5060 IF A$ = "R" THEN INPUT "AMOUNT? ";Q : IF Q > 0 AND Q <= CA AND Q <= DE THEN CA = CA - Q : DE = DE - Q : AC = 1
5070 RETURN

5500 REM ======= PROTECTION =======
5510 IF SD = DY THEN GOTO 5540
5520 SD = DY : SC = SL + INT(RND(1) * SV)
5540 MX = INT(CA / SC)
5550 IF MX < 1 THEN M$ = "NOTHING YOU CAN AFFORD TODAY." : RETURN
5560 PRINT "A SHOP IS GOING FOR $";SC;". YOU CAN AFFORD ";MX;"."
5570 PRINT "HOW MANY? (ENTER FOR ";MX;") ";: INPUT A$
5580 Q = MX : IF A$ <> "" THEN Q = VAL(A$)
5590 IF Q < 1 OR Q > MX THEN RETURN
5600 CA = CA - Q * SC : SH = SH + Q : AC = 1
5610 PS = SH : FM = MU - HG + 1 : IF PS > FM THEN PS = FM
5620 IF PS < 1 THEN PS = 1
5630 B$ = "S" : IF SH = 1 THEN B$ = ""
5640 M$ = "YOU NOW HAVE " + STR$(SH) + " SHOP" + B$ + " ON YOUR BOOKS"
5650 IF PS = SH THEN M$ = M$ + " AND PAYING PROTECTION." : RETURN
5660 C$ = "S" : IF PS = 1 THEN C$ = ""
5670 M$ = M$ + " AND " + STR$(PS) + " SHOP" + C$ + " PAYING PROTECTION."
5680 RETURN

5700 REM ======= MUSCLE =======
5710 G$ = "S" : IF MU = 1 THEN G$ = ""
5720 PRINT "YOU HAVE ";MU;" GUY";G$;" AT $";PW;"/WEEK EACH."
5730 PRINT "(H)IRE  (F)IRE";
5740 GET A$ : PRINT
5750 IF A$ = "H" THEN GOSUB 5800
5760 IF A$ = "F" THEN GOSUB 5900
5770 RETURN

5800 REM ======= HIRE =======
5810 MX = INT(CA / PW) - MU
5820 IF MX < 1 THEN M$ = "YOU CAN'T COVER ANOTHER GUY'S PAY." : RETURN
5830 PRINT "YOU CAN COVER ";MX;" MORE. HOW MANY? (ENTER FOR 1) ";: INPUT A$
5840 Q = 1 : IF A$ <> "" THEN Q = VAL(A$)
5850 IF Q < 1 OR Q > MX THEN RETURN
5860 MU = MU + Q : AC = 1
5870 GOSUB 5990
5880 RETURN

5900 REM ======= FIRE =======
5910 MX = MU - HG
5920 IF MX < 1 THEN M$ = "NOBODY YOU CAN LET GO RIGHT NOW." : RETURN
5930 PRINT "YOU CAN LET GO ";MX;". HOW MANY? (ENTER FOR 1) ";: INPUT A$
5940 Q = 1 : IF A$ <> "" THEN Q = VAL(A$)
5950 IF Q < 1 OR Q > MX THEN RETURN
5960 MU = MU - Q : AC = 1
5970 GOSUB 5990
5980 RETURN

5990 REM ======= MUSCLE MESSAGE =======
5992 G$ = "S" : IF MU = 1 THEN G$ = ""
5994 M$ = "YOU NOW HAVE " + STR$(MU) + " GUY" + G$ + ". PAYROLL $" + STR$(MU * PW) + "/WEEK."
5996 RETURN

6000 REM ======= COP BRIBE DEMAND =======
6010 BR = 300 + INT(RND(1) * 1200)
6015 IF HT = 1 THEN BR = BR * 3 : PRINT "WORD TRAVELS FAST."
6020 IF CA < BR THEN CP = -1 : E$ = "THE COPS WANTED $" + STR$(BR) + ". YOU COULDN'T PAY. YOU'RE ON THEIR LIST." : GOSUB 8000 : RETURN
6030 PRINT "THE COPS WANT $";BR;". PAY? (Y/N)";
6040 GET A$ : PRINT
6050 IF A$ = "N" THEN CP = -1 : E$ = "YOU'RE ON THE COPS' LIST NOW." : GOSUB 8000 : RETURN
6060 CA = CA - BR : CP = 1 : CC = 14 : E$ = "THE COPS LOOK THE OTHER WAY... FOR NOW." : GOSUB 8000
6070 RETURN

6500 REM ======= ROBBERY =======
6510 IF V(1) + V(2) + V(3) = 0 THEN M$ = "ROBBERS CAME AND FOUND NOTHING. THEY TOOK IT OUT ON YOU." : GO = 1 : RETURN
6520 FOR J = 1 TO 3 : V(J) = 0 : NEXT J
6530 E$ = "YOU GOT ROBBED. YOUR ENTIRE STASH IS GONE." : GOSUB 8000
6540 RETURN

6600 REM ======= LOAN REQUEST =======
6610 IF NL >= 8 THEN RETURN
6620 LA = 200 + INT(RND(1) * 1300)
6630 IF CA < LA THEN RETURN
6640 PRINT "A GUY NEEDS $";LA;". LEND IT? HE'LL OWE $";INT(LA * 1.5);" (Y/N)";
6650 GET A$ : PRINT : IF A$ <> "Y" THEN RETURN
6660 CA = CA - LA : NL = NL + 1 : LB(NL) = INT(LA * 1.5) : AC = 1
6670 E$ = "YOU PUT $" + STR$(LA) + " ON THE STREET." : GOSUB 8000
6680 RETURN

7000 REM ======= PICK COMMODITY =======
7005 IF SM = 1 THEN PRINT "SELL: "; : GOTO 7020
7010 PRINT "BUY: ";
7020 FOR I = 1 TO 3
7030 IF SM = 1 AND V(I) = 0 THEN GOTO 7050
7040 PRINT "(";LEFT$(N$(I), 1);")";MID$(N$(I), 2);" ";
7050 NEXT I
7060 PRINT "OR ENTER TO CANCEL";
7070 GET A$ : PRINT
7080 J = 0
7090 IF A$ = "W" THEN J = 1
7100 IF A$ = "P" THEN J = 2
7110 IF A$ = "C" THEN J = 3
7120 IF SM = 1 AND J > 0 AND V(J) = 0 THEN J = 0 : GOTO 7070
7130 IF J = 0 AND A$ <> CHR$(13) THEN GOTO 7070
7140 RETURN

7500 REM ======= HIT OFFER =======
7510 PRINT "YOUR GUYS KNOW A RIVAL STASH. SEND 3 FOR 3 DAYS? (Y/N)";
7520 GET A$ : PRINT : IF A$ <> "Y" THEN RETURN
7530 HG = 3 : HD = 3
7540 E$ = "THREE GUYS ARE OUT ON A JOB." : GOSUB 8000
7550 RETURN

7600 REM ======= HIT RESOLVES =======
7610 IF RND(1) > .4 + MU * .06 THEN MU = MU - 3 : HG = 0 : E$ = "IT WENT BAD. ALL THREE ARE GONE." : GOSUB 8000 : GOTO 7660
7620 J = 1 + INT(RND(1) * 3) : Q = INT(DM(J) * (.5 + RND(1) * 2)) : V(J) = V(J) + Q
7630 E$ = "THEY CAME BACK WITH " + STR$(Q) + " UNITS OF " + N$(J) + "."
7640 IF RND(1) < .35 THEN MU = MU - 1 : E$ = E$ + " ONE DIDN'T COME BACK."
7650 GOSUB 8000 : HG = 0
7660 HT = 1 : GOSUB 6000 : HT = 0
7670 RETURN

8000 REM ======= APPEND MESSAGE (E$ IN) =======
8010 IF M$ = "" THEN M$ = E$ : RETURN
8020 M$ = M$ + "  " + E$
8030 RETURN

9000 REM ======= INIT =======
9010 CA = 2000 : DE = 0 : SH = 0 : MU = 0 : CP = 0 : CC = 0 : QT = 0 : GO = 0 : M$ = ""
9012 DY = 0 : WD = 0
9020 DIM N$(3), P(3), B(3), V(3)
9025 DIM D(3), DM(3), LB(8)
9030 N$(1) = "WEED" : B(1) = 80
9040 N$(2) = "PILLS" : B(2) = 40
9050 N$(3) = "COKE" : B(3) = 300
9060 DM(1) = 100 : DM(2) = 25 : DM(3) = 8
9070 SR = 250 : PW = 150 : SL = 800 : SV = 900
9075 DW$ = "MONTUEWEDTHUFRISATSUN"
9080 FOR J = 1 TO 3 : P(J) = B(J) : V(J) = 0 : D(J) = DM(J) : NEXT J
9090 NL = 0 : HG = 0 : HD = 0 : HT = 0 : NT = 0 : SD = -1
9095 RETURN
